{
    "name": "sitakgmbh/lara-base",
    "description": "Sitak GmbH – Laravel Base Package",
    "type": "library",
	"require": {
		"php": "^8.2",
		"illuminate/support": "^11.0|^12.0|^13.0",
		"livewire/livewire": "^4.0",
		"directorytree/ldaprecord-laravel": "^3.0",
		"spatie/laravel-permission": "^6.0",
		"laravel-notification-channels/webpush": "dev-master@dev",
		"minishlink/web-push": "^10.0"
	},
    "autoload": {
        "psr-4": {
            "Sitakgmbh\\LaraBase\\": "src/",
            "Sitakgmbh\\LaraBase\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sitakgmbh\\LaraBase\\LaraBaseServiceProvider"
            ],
			"aliases": {
				"LaraLog":      "Sitakgmbh\\LaraBase\\Facades\\LaraLog",
				"LaraSettings": "Sitakgmbh\\LaraBase\\Facades\\LaraSettings",
				"LaraUserSettings": "Sitakgmbh\\LaraBase\\Facades\\LaraUserSettings",
				"LaraNotify":   "Sitakgmbh\\LaraBase\\Facades\\LaraNotify"
			}
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}